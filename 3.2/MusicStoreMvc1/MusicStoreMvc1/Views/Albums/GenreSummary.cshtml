@model IEnumerable<dynamic>

@{
    ViewData["Title"] = "Genre Summary";
}

<h1>Genre Summary</h1>
<p>Album statistics grouped by genre.</p>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Genre</th>
            <th>Albums</th>
            <th>Average Price</th>
            <th>Cheapest</th>
            <th>Most Expensive</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Genre</td>
                <td>@item.AlbumCount</td>
                <td>@item.AveragePrice.ToString("C")</td>
                <td>@item.Cheapest.ToString("C")</td>
                <td>@item.MostExpensive.ToString("C")</td>
            </tr>
        }
    </tbody>
</table>

<p><a asp-action="Index">Back to Albums</a></p> 